{
  "name": "RPG Formula",
  "scopeName": "source.rpgformula",
  "fileTypes": [
    "rpgf"
  ],
  "patterns": [
    { "include": "#whitespace" },
    { "include": "#comments" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#identifiers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "whitespace": {
      "patterns": [
        {
          "name": "text.whitespace",
          "match": "[\\t\\x20]+"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash",
          "match": "//.*$"
        },
        {
          "name": "comment.block",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "match": "[\\s\\S]" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float",
          "match": "\\b((\\d+_)?\\d+\\.\\d+|\\.\\d+|\\d+\\.)([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function",
          "match": "\\b(?:min|max|clamp|abs|ceil|floor|round|sqrt|pow|lerp|sin|cos|tan|asin|acos|atan|atan2|log|mod)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic",
          "match": "[+\\-*/%\\^]"
        },
        {
          "name": "keyword.operator.logical",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.comparison",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.prefix",
          "match": "!"
        },
        {
          "name": "keyword.operator.ternary",
          "match": "\\?|:"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.parenthesis.open",
          "match": "\\("
        },
        {
          "name": "punctuation.parenthesis.close",
          "match": "\\)"
        },
        {
          "name": "punctuation.bracket.open",
          "match": "\\["
        },
        {
          "name": "punctuation.bracket.close",
          "match": "\\]"
        },
        {
          "name": "punctuation.accessor.dot",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.comma",
          "match": ","
        }
      ]
    }
  }
}
